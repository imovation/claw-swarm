#!/bin/bash
# bin/claw-port — 变更 Pod 运行端口（声明式：同步修改 swarm.yaml + 服务文件）
# 
# 注意：这是一个命令式快捷工具。如需持久化端口变更，请直接编辑 swarm.yaml
# 后运行 claw-apply，那才是声明式的正确做法。本脚本会同步修改两处以保持一致。
#
# 用法:  ./claw-port <PROFILE_NAME> <NEW_PORT>
# 示例:  ./claw-port aimee 18990
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/pod_utils.sh
source "$SCRIPT_DIR/../lib/pod_utils.sh"

SWARM_YAML="$SCRIPT_DIR/../swarm.yaml"

# ── 参数校验 ──────────────────────────────────────────────────────────────────
if [ "$#" -lt 2 ]; then
    echo "用法: $(basename "$0") <PROFILE_NAME> <NEW_PORT>"
    echo "示例: $(basename "$0") aimee 18990"
    exit 1
fi

resolve_pod "$1"
NEW_PORT="$2"

# 校验端口格式
if ! [[ "$NEW_PORT" =~ ^[0-9]{4,5}$ ]]; then
    echo "❌ 端口号格式无效: '$NEW_PORT'，请输入有效的数字端口 (1024-65535)。"
    exit 1
fi

echo "🔌 [1/3] 正在更新服务文件端口: $SERVICE_NAME → :$NEW_PORT..."

# 检查服务文件是否存在
if [ ! -f "$SERVICE" ]; then
    echo "❌ 找不到服务文件: $SERVICE"
    echo "   提示: 请先使用 claw-apply 创建该 Pod。"
    exit 1
fi

NODE_BIN=$(get_node_binary)
OPENCLAW_BIN=$(get_openclaw_binary)

# 修改 ExecStart 中的端口参数（精确替换 --port 值，不破坏其他参数）
if [[ "$RESOLVED_PROFILE" == "default" ]]; then
    sed -i "s|ExecStart=.*|ExecStart=$NODE_BIN $OPENCLAW_BIN gateway run --port $NEW_PORT|" "$SERVICE"
else
    sed -i "s|ExecStart=.*|ExecStart=$NODE_BIN $OPENCLAW_BIN --profile $RESOLVED_PROFILE gateway run --port $NEW_PORT|" "$SERVICE"
fi

echo "📄 [2/3] 正在同步 swarm.yaml 中的端口声明..."

# 找到 swarm.yaml 中对应 profile 的 pod 块，并更新 port 字段
# 使用 Python 进行精确的 YAML 修改，避免 sed 的 YAML 结构风险
python3 - <<PYEOF
import yaml, sys
from pathlib import Path

swarm_path = Path("$SWARM_YAML")
if not swarm_path.exists():
    print("  ⚠️  swarm.yaml 不存在，跳过声明文件同步。")
    sys.exit(0)

with open(swarm_path, "r") as f:
    config = yaml.safe_load(f)

profile_input = "$1"
new_port = int("$NEW_PORT")
updated = False

for pod in config.get("pods", []):
    # 匹配 name 或 profile 字段
    if pod.get("profile") == profile_input or pod.get("name") == profile_input:
        old_port = pod.get("port")
        pod["port"] = new_port
        updated = True
        print(f"  已更新: {pod['name']} 端口 {old_port} → {new_port}")
        break

if not updated:
    print(f"  ⚠️  在 swarm.yaml 中未找到 profile='{profile_input}' 的 Pod，仅修改了服务文件。")
else:
    with open(swarm_path, "w") as f:
        yaml.dump(config, f, allow_unicode=True, default_flow_style=False, sort_keys=False)
    print(f"  swarm.yaml 已保存。")
PYEOF

echo "♻️  [3/3] 正在重载 Systemd 并重启实例..."
systemd_reload_restart "$SERVICE_NAME"

echo ""
echo "✅ Pod '$1' 端口已成功变更为 $NEW_PORT。"
echo "   查看日志: journalctl --user -fu $SERVICE_NAME.service"
