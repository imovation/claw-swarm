#!/bin/bash
# bin/claw-bot-add — 为 Pod 添加额外的飞书机器人
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

if [ "$#" -lt 4 ]; then
    echo "用法: $(basename "$0") <PROFILE_NAME> <BOT_ID> <APP_ID> <APP_SECRET> [ALLOW_USER_ID]"
    echo ""
    echo "参数说明:"
    echo "  PROFILE_NAME     Pod 名称 (如 aimee, main)"
    echo "  BOT_ID           机器人标识 (如 bot2, bot3)"
    echo "  APP_ID           飞书应用 App ID"
    echo "  APP_SECRET       飞书应用 App Secret"
    echo "  ALLOW_USER_ID    可选: 允许的用户飞书 ID (ou_xxx)"
    echo ""
    echo "示例: $(basename "$0") aimee bot2 cli_xxx yyy"
    echo "      $(basename "$0") aimee bot3 cli_aaa bbb ou_123"
    exit 1
fi

PROFILE_INPUT="$1"
BOT_ID="$2"
APP_ID="$3"
APP_SECRET="$4"
ALLOW_USER_ID="${5:-}"

resolve_pod "$PROFILE_INPUT"

if [ ! -d "$DIR" ]; then
    echo "❌ 错误: Pod '$PROFILE_INPUT' 不存在"
    exit 1
fi

CONFIG="$DIR/openclaw.json"

echo "🚀 正在为 Pod '$PROFILE_INPUT' 添加飞书机器人 '$BOT_ID'..."

echo "📝 [1/3] 配置飞书账号..."
openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.appId" "$APP_ID"
openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.appSecret" "$APP_SECRET"
openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.dmPolicy" "allowlist"

if [ -n "$ALLOW_USER_ID" ]; then
    echo "👤 [2/3] 添加用户白名单..."
    openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.allowFrom" "[\"$ALLOW_USER_ID\"]"
else
    echo "⚠️  [2/3] 未指定用户，将阻止所有非白名单用户"
fi

echo "🔄 [3/3] 重启服务..."
systemctl --user restart "$SERVICE_NAME.service"

echo ""
echo "✅ 飞书机器人 '$BOT_ID' 已添加到 Pod '$PROFILE_INPUT'"
echo "   Bot ID: $BOT_ID"
echo "   App ID: $APP_ID"
