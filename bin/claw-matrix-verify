#!/bin/bash
# bin/claw-matrix-verify — Matrix E2EE 验证管理工具
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

usage() {
    echo "用法: $(basename "$0") <PROFILE> <COMMAND> [OPTIONS]"
    echo ""
    echo "Matrix E2EE 验证与加密管理工具"
    echo ""
    echo "命令:"
    echo "  status              检查 E2EE 状态"
    echo "  status --verbose   详细诊断信息"
    echo "  status --json      机器可读输出"
    echo "  bootstrap          引导交叉签名和密钥备份"
    echo "  bootstrap --force-reset-cross-signing  强制重置交叉签名"
    echo "  backup status     检查密钥备份健康状态"
    echo "  backup restore    从服务器恢复密钥备份"
    echo "  backup reset      重置密钥备份"
    echo "  device <key>      使用恢复密钥验证设备"
    echo ""
    echo "选项:"
    echo "  --account <id>     指定 Matrix 账号 (多账号时使用)"
    echo "  --verbose          显示详细诊断"
    echo "  --json             JSON 格式输出"
    echo ""
    echo "示例:"
    echo "  $(basename "$0") default status"
    echo "  $(basename "$0") default status --verbose"
    echo "  $(basename "$0") default bootstrap"
    echo "  $(basename "$0") default backup status --verbose"
    exit 1
}

if [ "$#" -lt 2 ]; then
    usage
fi

PROFILE="$1"
COMMAND="$2"
shift 2

ACCOUNT=""
VERBOSE=""
JSON_OUTPUT=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --account) ACCOUNT="$2"; shift 2 ;;
        --verbose) VERBOSE="--verbose"; shift ;;
        --json) JSON_OUTPUT="--json"; shift ;;
        --force-reset-cross-signing) VERBOSE="--verbose --force-reset-cross-signing"; shift ;;
        *) echo "未知选项: $1"; usage ;;
    esac
done

resolve_pod "$PROFILE"

export OPENCLAW_STATE_DIR="$DIR"
export OPENCLAW_CONFIG_PATH="$DIR/openclaw.json"
export TMPDIR="$DIR/runtime/tmp"
export XDG_CONFIG_HOME="$DIR/runtime/config"
export XDG_CACHE_HOME="$DIR/runtime/cache"
export XDG_DATA_HOME="$DIR/runtime/data"

NODE_BIN=$(get_node_binary)
CLAW_BIN=$(get_openclaw_binary)

ACCOUNT_ARG=""
[ -n "$ACCOUNT" ] && ACCOUNT_ARG="--account $ACCOUNT"

echo "🔐 Matrix 验证工具 (Pod: $PROFILE)"
echo "========================================"

case "$COMMAND" in
    status)
        echo ""
        echo "📊 正在检查 E2EE 状态..."
        $NODE_BIN $CLAW_BIN matrix verify status $VERBOSE $JSON_OUTPUT $ACCOUNT_ARG
        ;;
    bootstrap)
        echo ""
        echo "🔧 正在引导交叉签名和密钥备份..."
        $NODE_BIN $CLAW_BIN matrix verify bootstrap $VERBOSE $ACCOUNT_ARG
        ;;
    backup)
        case "${1:-}" in
            status)
                echo ""
                echo "📦 正在检查密钥备份健康状态..."
                $NODE_BIN $CLAW_BIN matrix verify backup status $VERBOSE $JSON_OUTPUT $ACCOUNT_ARG
                ;;
            restore)
                echo ""
                echo "📥 正在从服务器恢复密钥备份..."
                $NODE_BIN $CLAW_BIN matrix verify backup restore $VERBOSE $ACCOUNT_ARG
                ;;
            reset)
                echo ""
                echo "⚠️  正在重置密钥备份..."
                read -p "确认重置? (输入 'yes' 确认): " confirm
                if [ "$confirm" = "yes" ]; then
                    $NODE_BIN $CLAW_BIN matrix verify backup reset --yes $VERBOSE $ACCOUNT_ARG
                else
                    echo "已取消。"
                fi
                ;;
            *)
                echo "未知 backup 子命令: ${1:-}"
                echo "可用: status, restore, reset"
                exit 1
                ;;
        esac
        ;;
    device)
        if [ -z "${1:-}" ]; then
            echo "错误: device 命令需要恢复密钥参数"
            exit 1
        fi
        echo ""
        echo "🔑 正在验证设备..."
        $NODE_BIN $CLAW_BIN matrix verify device "$1" $VERBOSE $ACCOUNT_ARG
        ;;
    *)
        echo "未知命令: $COMMAND"
        usage
        ;;
esac