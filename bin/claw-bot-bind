#!/bin/bash
# bin/claw-bot-bind — 绑定飞书机器人到指定 Agent
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

if [ "$#" -lt 3 ]; then
    echo "用法: $(basename "$0") <PROFILE_NAME> <BOT_ID> <AGENT_NAME>"
    echo ""
    echo "参数说明:"
    echo "  PROFILE_NAME  Pod 名称 (如 aimee)"
    echo "  BOT_ID        机器人标识 (如 bot2)"
    echo "  AGENT_NAME    Agent 名称"
    echo ""
    echo "示例: $(basename "$0") aimee bot2 aimee2"
    exit 1
fi

PROFILE_INPUT="$1"
BOT_ID="$2"
AGENT_NAME="$3"

resolve_pod "$PROFILE_INPUT"

if [ ! -d "$DIR" ]; then
    echo "❌ 错误: Pod '$PROFILE_INPUT' 不存在"
    exit 1
fi

echo "🔗 正在绑定飞书机器人 '$BOT_ID' 到 Agent '$AGENT_NAME'..."
openclaw --profile "$RESOLVED_PROFILE" agents bind "$AGENT_NAME" --channel feishu --account "$BOT_ID"

echo "🔄 重启服务..."
systemctl --user restart "$SERVICE_NAME.service"

echo ""
echo "✅ 绑定完成"
echo "   Bot: $BOT_ID → Agent: $AGENT_NAME"
