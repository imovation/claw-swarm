#!/bin/bash
# claw-swarm: Enhanced Process Status Monitor
set -e

# 颜色定义
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# 表格头 (增加 MODEL 和 CHANNELS)
printf "%-12s %-10s %-8s %-12s %-25s %-15s\n" "INSTANCE" "STATUS" "PORT" "UPTIME" "MODEL" "CHANNELS"
echo "------------------------------------------------------------------------------------------------------------------------"

# 获取所有 openclaw-gateway* 服务
services=$(systemctl --user list-units "openclaw-gateway*" --all --no-legend | awk '{print $1}')

for service in $services; do
    # 提取实例名
    if [ "$service" == "openclaw-gateway.service" ]; then
        name="main"
        config_file="/home/imovation/.openclaw/openclaw.json"
    else
        name=$(echo $service | sed 's/openclaw-gateway-//; s/.service//')
        config_file="/home/imovation/.openclaw-$name/openclaw.json"
    fi
    
    # 获取运行状态
    status=$(systemctl --user is-active $service || echo "inactive")
    
    # 默认值
    model="N/A"
    channels="none"
    port="N/A"
    uptime_short="N/A"

    if [ "$status" == "active" ]; then
        # 获取端口
        port=$(systemctl --user show -p ExecStart $service | sed -n 's/.*--port \([0-9]*\).*/\1/p' || echo "")
        [ -z "$port" ] && port="18789"
        
        # 获取 Uptime
        uptime=$(systemctl --user show -p ActiveEnterTimestamp $service | cut -d= -f2)
        uptime_short=$(echo $uptime | awk '{print $2 " " $3}')

        # 提取配置信息 (使用 grep/sed 快速解析 JSON)
        if [ -f "$config_file" ]; then
            # 提取主要模型 (agents.defaults.model.primary)
            model=$(grep -oP '"primary":\s*"\K[^"]+' "$config_file" | head -n 1 || echo "default")
            # 提取已开启的渠道 (查找 enabled: true 的父键名)
            channels=$(grep -B 1 '"enabled":\s*true' "$config_file" | grep -oP '"\K[^"]+(?=":\s*\{)' | tr '\n' ',' | sed 's/,$//' || echo "none")
            [ -z "$channels" ] && channels="none"
        fi
    fi

    # 格式化输出
    printf "%-12s %-10s %-8s %-12s %-25s %-15s\n" "$name" "$status" "$port" "$uptime_short" "${model:0:24}" "$channels"
done
