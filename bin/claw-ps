#!/bin/bash
# claw-swarm: Process Status Monitor (Like docker ps)
set -e

# 表格头
printf "%-20s %-10s %-8s %-12s %-8s %-10s\n" "INSTANCE" "STATUS" "PORT" "UPTIME" "CPU" "MEMORY"
echo "---------------------------------------------------------------------------------------"

# 获取所有 openclaw-* 服务
services=$(systemctl --user list-units "openclaw-*" --all --no-legend | awk '{print $1}')

for service in $services; do
    # 提取实例名
    name=$(echo $service | sed 's/openclaw-//; s/.service//')
    
    # 获取运行状态
    status=$(systemctl --user is-active $service || echo "inactive")
    
    if [ "$status" == "active" ]; then
        # 获取 PID
        pid=$(systemctl --user show -p MainPID $service | cut -d= -f2)
        
        # 获取端口 (从 ExecStart 属性中提取)
        port=$(systemctl --user show -p ExecStart $service | sed -n 's/.*--port \([0-9]*\).*/\1/p' || echo "N/A")
        [ -z "$port" ] && port="18789" # 主实例默认端口
        
        # 获取 Uptime
        uptime=$(systemctl --user show -p ActiveEnterTimestamp $service | cut -d= -f2)
        # 简化 uptime 格式 (只保留日期和时间)
        uptime_short=$(echo $uptime | awk '{print $2 " " $3}')

        # 获取资源占用 (使用 ps)
        res=$(ps -p $pid -o %cpu,%mem --no-headers 2>/dev/null || echo "0.0 0.0")
        cpu=$(echo $res | awk '{print $1 "%"}')
        mem=$(echo $res | awk '{print $2 "%"}')
    else
        pid="N/A"
        port="N/A"
        uptime_short="N/A"
        cpu="0%"
        mem="0%"
    fi

    # 格式化输出
    printf "%-20s %-10s %-8s %-12s %-8s %-10s\n" "$name" "$status" "$port" "$uptime_short" "$cpu" "$mem"
done
