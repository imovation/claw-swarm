#!/bin/bash
# claw-swarm: Precise Process Status Monitor
#
# 📋 [待迁移 PENDING MIGRATION] 归属模块：
#     modules/orchestration/
set -e

# 表格头
printf "%-12s %-8s %-8s %-25s %-12s %-20s\n" "INSTANCE" "STATUS" "PORT" "MODEL" "CHANNELS" "PLUGINS"
echo "------------------------------------------------------------------------------------------------------------------------"

services=$(systemctl --user list-units "openclaw-gateway*" --all --no-legend | awk '{print $1}')

for service in $services; do
    if [ "$service" == "openclaw-gateway.service" ]; then
        name="main"
        config_file="/home/imovation/.openclaw/openclaw.json"
    else
        name=$(echo $service | sed 's/openclaw-gateway-//; s/.service//')
        config_file="/home/imovation/.openclaw-$name/openclaw.json"
    fi
    
    status=$(systemctl --user is-active $service || echo "inactive")
    model="N/A"
    msg_channels="none"
    active_plugins="none"
    port="N/A"

    if [ "$status" == "active" ]; then
        port=$(systemctl --user show -p ExecStart $service | sed -n 's/.*--port \([0-9]*\).*/\1/p' || echo "18789")
        
        if [ -f "$config_file" ]; then
            # 1. 提取模型
            model=$(grep -oP '"primary":\s*"\K[^"]+' "$config_file" | head -n 1 || echo "default")
            
            # 2. 提取消息通道 (提取 channels 块直至第一个关闭括号)
            msg_channels=$(sed -n '/"channels": {/,/^  }/p' "$config_file" | grep -B 1 '"enabled":\s*true' | grep -oP '"\K[^"]+(?=":\s*\{)' | tr '\n' ',' | sed 's/,$//')
            [ -z "$msg_channels" ] && msg_channels="none"

            # 3. 提取核心插件 (提取 plugins 块直至第一个关闭括号)
            active_plugins=$(sed -n '/"plugins": {/,/^  }/p' "$config_file" | grep -B 1 '"enabled":\s*true' | grep -oP '"\K[^"]+(?=":\s*\{)' | tr '\n' ',' | sed 's/,$//')
            [ -z "$active_plugins" ] && active_plugins="none"
        fi
    fi

    printf "%-12s %-8s %-8s %-25s %-12s %-20s\n" "$name" "$status" "$port" "${model:0:24}" "$msg_channels" "$active_plugins"
done
