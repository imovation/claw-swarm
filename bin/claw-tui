#!/usr/bin/env python3
import os
import yaml
import sys
import subprocess

CONFIG_FILE = "/home/imovation/claw-swarm/swarm.yaml"

def main():
    if len(sys.argv) < 2:
        print("用法: ./claw-tui <实例名>")
        print("示例: ./claw-tui aimee")
        sys.exit(1)

    name = sys.argv[1]

    if not os.path.exists(CONFIG_FILE):
        print(f"❌ 错误: 找不到配置文件 {CONFIG_FILE}。")
        sys.exit(1)

    with open(CONFIG_FILE, 'r') as f:
        config = yaml.safe_load(f)

    pod = next((p for p in config.get('pods', []) if p['name'] == name), None)

    if not pod:
        print(f"❌ 错误: 在 swarm.yaml 中找不到名为 '{name}' 的实例配置。")
        sys.exit(1)

    profile = pod.get('profile', name)
    token = pod['token']
    
    # 确定路径 (与 clawctl 保持一致)
    if profile in ["default", "main"]:
        dir_path = "/home/imovation/.openclaw"
        profile_arg = "default"
    else:
        dir_path = f"/home/imovation/.openclaw-{profile}"
        profile_arg = profile

    # 注入与后台 Service 一致的隔离环境变量 (Virtual Home)
    env = os.environ.copy()
    env["TMPDIR"] = f"{dir_path}/runtime/tmp"
    env["XDG_CONFIG_HOME"] = f"{dir_path}/runtime/config"
    env["XDG_CACHE_HOME"] = f"{dir_path}/runtime/cache"
    env["XDG_DATA_HOME"] = f"{dir_path}/runtime/data"
    
    # 注入浏览器隔离 (如果需要)
    if pod.get('resources', {}).get('browser', 'dedicated') == 'dedicated':
        env["PUPPETEER_USER_DATA_DIR"] = f"{dir_path}/runtime/browser"

    print(f"🚀 正在进入实例 '{name}' (Profile: {profile_arg}) 的终端界面...")
    
    # 构建命令
    cmd = ["openclaw"]
    if profile_arg != "default":
        cmd += ["--profile", profile_arg]
    cmd += ["tui", "--token", token]

    try:
        subprocess.run(cmd, env=env)
    except KeyboardInterrupt:
        print("\n👋 已退出终端界面。")
    except Exception as e:
        print(f"❌ 启动 TUI 失败: {e}")

if __name__ == "__main__":
    main()
