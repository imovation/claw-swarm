#!/bin/bash
# bin/clawctl — 声明式 Pod 供应脚本 (修复版：更新配置格式)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

if [ "$#" -lt 3 ]; then
    echo "用法: $(basename "$0") <PROFILE> <PORT> <TOKEN> [BROWSER_MODE] [PLUGINS_COMMA] [PROXY_JSON]"
    exit 1
fi

PROFILE_INPUT="$1"
PORT="$2"
TOKEN="$3"
BROWSER_MODE=${4:-dedicated}
PLUGINS_INPUT=${5:-""}
PROXY_JSON=${6:-"{}"}

resolve_pod "$PROFILE_INPUT"

echo "🚀 正在供应 Pod: $PROFILE_INPUT (端口: $PORT, 插件: $PLUGINS_INPUT)..."

# 1. 环境准备
mkdir -p "$DIR/runtime/tmp" "$DIR/runtime/config" "$DIR/runtime/cache" "$DIR/runtime/data" "$DIR/runtime/browser"

# 2. 同步插件
if [ -n "$PLUGINS_INPUT" ]; then
    sync_plugins "$DIR" "$PLUGINS_INPUT"
fi

# 3. 注入 EnvironmentFile (env 文件)
ENV_FILE="$DIR/runtime/env"
NODE_BIN=$(get_node_binary)
NODE_PATH=$(dirname "$NODE_BIN")

cat << ENV_EOF > "$ENV_FILE"
OPENCLAW_PORT=$PORT
OPENCLAW_TOKEN=$TOKEN
OPENCLAW_PROFILE=$RESOLVED_PROFILE
OPENCLAW_STATE_DIR=$DIR
OPENCLAW_CONFIG_PATH=$DIR/openclaw.json
TMPDIR=$DIR/runtime/tmp
XDG_CONFIG_HOME=$DIR/runtime/config
XDG_CACHE_HOME=$DIR/runtime/cache
XDG_DATA_HOME=$DIR/runtime/data
PATH=$NODE_PATH:/usr/local/bin:/usr/bin:/bin
ENV_EOF

if [ "$BROWSER_MODE" == "dedicated" ]; then
    echo "PUPPETEER_USER_DATA_DIR=$DIR/runtime/browser" >> "$ENV_FILE"
fi

# 注入代理
if command -v jq >/dev/null 2>&1; then
    HTTP_P=$(echo "$PROXY_JSON" | jq -r '.http // empty')
    HTTPS_P=$(echo "$PROXY_JSON" | jq -r '.https // empty')
    SOCKS_P=$(echo "$PROXY_JSON" | jq -r '.socks // empty')
    NO_P=$(echo "$PROXY_JSON" | jq -r '.no_proxy // empty')
    [ -n "$HTTP_P" ] && echo "HTTP_PROXY=$HTTP_P" >> "$ENV_FILE" && echo "http_proxy=$HTTP_P" >> "$ENV_FILE"
    [ -n "$HTTPS_P" ] && echo "HTTPS_PROXY=$HTTPS_P" >> "$ENV_FILE" && echo "https_proxy=$HTTPS_P" >> "$ENV_FILE"
    [ -n "$SOCKS_P" ] && echo "ALL_PROXY=$SOCKS_P" >> "$ENV_FILE" && echo "all_proxy=$SOCKS_P" >> "$ENV_FILE"
    [ -n "$NO_P" ] && echo "NO_PROXY=$NO_P" >> "$ENV_FILE" && echo "no_proxy=$NO_P" >> "$ENV_FILE"
fi

# 4. 确保配置文件存在且格式正确 (OpenClaw 2026.4.8 格式)
if [ ! -f "$DIR/openclaw.json" ] || ! grep -q "\"gateway\"" "$DIR/openclaw.json"; then
    echo "正在为 $PROFILE_INPUT 创建或升级配置文件..."
    cat << JSON_EOF > "$DIR/openclaw.json"
{
  "agents": {
    "defaults": {
      "workspace": "./workspace"
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "$TOKEN"
    },
    "port": $PORT,
    "bind": "loopback"
  }
}
JSON_EOF
fi

# 5. 启动管理
TEMPLATE_SERVICE="openclaw-gateway@$RESOLVED_PROFILE"
if [ -f "$SERVICE" ]; then
    systemctl --user stop "$SERVICE_NAME.service" || true
    systemctl --user disable "$SERVICE_NAME.service" || true
    rm "$SERVICE"
fi

systemctl --user daemon-reload
systemctl --user enable "$TEMPLATE_SERVICE" --now
systemctl --user restart "$TEMPLATE_SERVICE"

pod_health_check "$TEMPLATE_SERVICE" "$PROFILE_INPUT" "$PORT"
