#!/bin/bash
# bin/claw-matrix-direct — Matrix 私信状态修复工具
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

usage() {
    echo "用法: $(basename "$0") <PROFILE> <COMMAND> [OPTIONS]"
    echo ""
    echo "Matrix 私信状态修复工具"
    echo ""
    echo "命令:"
    echo "  inspect --user-id <USER_ID>   检查私信映射状态"
    echo "  repair --user-id <USER_ID>    修复私信映射"
    echo ""
    echo "选项:"
    echo "  --user-id <USER_ID>   Matrix 用户 ID (如 @alice:example.org)"
    echo "  --account <id>       指定 Matrix 账号 (多账号时使用)"
    echo ""
    echo "示例:"
    echo "  $(basename "$0") default inspect --user-id @alice:example.org"
    echo "  $(basename "$0") default repair --user-id @alice:example.org"
    exit 1
}

if [ "$#" -lt 2 ]; then
    usage
fi

PROFILE="$1"
COMMAND="$2"
shift 2

USER_ID=""
ACCOUNT=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --user-id) USER_ID="$2"; shift 2 ;;
        --account) ACCOUNT="$2"; shift 2 ;;
        *) echo "未知选项: $1"; usage ;;
    esac
done

if [ -z "$USER_ID" ]; then
    echo "错误: 需要指定 --user-id 参数"
    usage
fi

resolve_pod "$PROFILE"

export OPENCLAW_STATE_DIR="$DIR"
export OPENCLAW_CONFIG_PATH="$DIR/openclaw.json"
export TMPDIR="$DIR/runtime/tmp"
export XDG_CONFIG_HOME="$DIR/runtime/config"
export XDG_CACHE_HOME="$DIR/runtime/cache"
export XDG_DATA_HOME="$DIR/runtime/data"

NODE_BIN=$(get_node_binary)
CLAW_BIN=$(get_openclaw_binary)

ACCOUNT_ARG=""
[ -n "$ACCOUNT" ] && ACCOUNT_ARG="--account $ACCOUNT"

echo "💬 Matrix 私信修复 (Pod: $PROFILE)"
echo "========================================"

case "$COMMAND" in
    inspect)
        echo ""
        echo "🔍 正在检查用户 $USER_ID 的私信映射..."
        $NODE_BIN $CLAW_BIN matrix direct inspect --user-id "$USER_ID" $ACCOUNT_ARG
        ;;
    repair)
        echo ""
        echo "🔧 正在修复用户 $USER_ID 的私信映射..."
        $NODE_BIN $CLAW_BIN matrix direct repair --user-id "$USER_ID" $ACCOUNT_ARG
        ;;
    *)
        echo "未知命令: $COMMAND"
        usage
        ;;
esac