#!/bin/bash
# bin/claw-rm — 删除 Pod（类 kubectl delete pod <name>）
# 使用共享库解决 profile 别名不一致问题
#
# 📋 [待迁移 PENDING MIGRATION] 归属模块：
#     modules/orchestration/pod-provisioner/
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/pod_utils.sh
source "$SCRIPT_DIR/../lib/pod_utils.sh"

# ── 参数校验 ──────────────────────────────────────────────────────────────────
if [ -z "${1:-}" ]; then
    echo "用法: $(basename "$0") <PROFILE_NAME>"
    echo "示例: $(basename "$0") bob"
    exit 1
fi

resolve_pod "$1"
# 现在我们有了导出的变量：$RESOLVED_PROFILE, $DIR, $SERVICE_NAME, $SERVICE

echo "🗑️  [1/3] 正在停止并禁用 Pod: $1 ($SERVICE_NAME)..."
if systemctl --user list-units --all | grep -q "$SERVICE_NAME.service"; then
    systemctl --user stop "$SERVICE_NAME.service" || true
    systemctl --user disable "$SERVICE_NAME.service" || true
fi

echo "🧹 [2/3] 正在移除 Systemd 服务文件..."
if [ -f "$SERVICE" ]; then
    rm "$SERVICE"
    systemctl --user daemon-reload
fi

echo "📂 [3/3] 正在删除配置目录: $DIR..."
if [ -d "$DIR" ]; then
    rm -rf "$DIR"
fi

echo "✅ Pod '$1' 已成功删除。"
