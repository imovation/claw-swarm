#!/bin/bash
# claw-swarm: Feishu/Lark Bot Integration Script (V9 - Multi-Bot Support)
set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
  echo "用法: $0 <PROFILE_NAME> [BOT_ID] [APP_ID] [APP_SECRET]"
  echo ""
  echo "参数说明:"
  echo "  PROFILE_NAME  Pod 名称 (如 aimee, main)"
  echo "  BOT_ID        可选: 机器人 ID (留空为主 bot)"
  echo "  APP_ID        可选: 飞书 App ID"
  echo "  APP_SECRET    可选: 飞书 App Secret"
  echo ""
  echo "示例:"
  echo "  $0 aimee                  # 交互式配置主 bot"
  echo "  $0 aimee bot2             # 交互式配置第二个 bot"
  echo "  $0 aimee bot2 cli_xxx yyy # 直接配置第二个 bot"
  echo ""
  echo "提示: 如需限制白名单，请在配置后编辑 ~/.openclaw*/openclaw.json"
  echo "      在 allowFrom 中添加用户的 open_id"
  exit 1
}

if [ "$#" -lt 1 ]; then
  usage
fi

PROFILE=$1
BOT_ID=${2:-""}
APP_ID=$3
APP_SECRET=$4

resolve_pod "$PROFILE"

if [ ! -d "$DIR" ]; then
  echo "❌ 错误: Profile '$PROFILE' 不存在"
  exit 1
fi

SERVICE_NAME_FULL="openclaw-gateway${PROFILE:+-$PROFILE}"
SERVICE_NAME_FULL=${SERVICE_NAME_FULL/openclaw-gateway-default/openclaw-gateway}

if [ -z "$APP_ID" ]; then
  echo -e "${BOLD}--- OpenClaw 飞书插件一键安装向导 ---${NC}"
  echo ""

  QUICK_CREATE_URL="https://open.feishu.cn/app?lang=zh-CN&from=openclaw_swarm"

  echo -e "${YELLOW}👉 请使用手机飞书扫描下方二维码，一键创建应用：${NC}"
  echo ""

  curl -L -s "qrenco.de/$QUICK_CREATE_URL" || echo -e "  ${BLUE}${BOLD}>> $QUICK_CREATE_URL <<${NC}"

  echo ""
  echo -e "${GREEN}1. 手机扫码或点击上方链接创建应用${NC}"
  echo -e "${GREEN}2. 应用名称请设为: ${BOLD}${PROFILE}${BOT_ID:+-$BOT_ID}-Bot${NC}"
  echo "3. 在"凭证与基础信息"获取 App ID 和 Secret"
  echo "-------------------------------------------------------"
  read -p "请输入 App ID: " APP_ID
  read -p "请输入 App Secret: " APP_SECRET
fi

echo -e "🚀 配置飞书机器人 ${BOT_ID:-default}..."

if [ -z "$BOT_ID" ]; then
  openclaw --profile "$RESOLVED_PROFILE" config set channels.feishu.enabled true
  openclaw --profile "$RESOLVED_PROFILE" config set channels.feishu.appId "$APP_ID"
  openclaw --profile "$RESOLVED_PROFILE" config set channels.feishu.appSecret "$APP_SECRET"
  openclaw --profile "$RESOLVED_PROFILE" config set channels.feishu.dmPolicy "open"
  openclaw --profile "$RESOLVED_PROFILE" config set channels.feishu.allowFrom '["*"]'
else
  openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.appId" "$APP_ID"
  openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.appSecret" "$APP_SECRET"
  openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.dmPolicy" "open"
  openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.accounts.${BOT_ID}.requireMention" true
fi

for tool in doc wiki drive bitable calendar task; do
  if [ -z "$BOT_ID" ]; then
    openclaw --profile "$RESOLVED_PROFILE" config set "channels.feishu.tools.$tool" true
  fi
done

systemctl --user restart "$SERVICE_NAME_FULL.service"
echo -e "${GREEN}✅ '$PROFILE' ${BOT_ID:+($BOT_ID) }配置成功！请在飞书测试。${NC}"
