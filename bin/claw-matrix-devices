#!/bin/bash
# bin/claw-matrix-devices — Matrix 设备管理工具
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

usage() {
    echo "用法: $(basename "$0") <PROFILE> <COMMAND> [OPTIONS]"
    echo ""
    echo "Matrix 设备管理工具"
    echo ""
    echo "命令:"
    echo "  list                列出当前账号的所有设备"
    echo "  prune-stale         清理过期的由 OpenClaw 管理的设备"
    echo ""
    echo "选项:"
    echo "  --account <id>     指定 Matrix 账号 (多账号时使用)"
    echo ""
    echo "示例:"
    echo "  $(basename "$0") default list"
    echo "  $(basename "$0") default prune-stale"
    echo "  $(basename "$0") aimee list --account assistant"
    exit 1
}

if [ "$#" -lt 2 ]; then
    usage
fi

PROFILE="$1"
COMMAND="$2"
shift 2

ACCOUNT=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --account) ACCOUNT="$2"; shift 2 ;;
        *) echo "未知选项: $1"; usage ;;
    esac
done

resolve_pod "$PROFILE"

export OPENCLAW_STATE_DIR="$DIR"
export OPENCLAW_CONFIG_PATH="$DIR/openclaw.json"
export TMPDIR="$DIR/runtime/tmp"
export XDG_CONFIG_HOME="$DIR/runtime/config"
export XDG_CACHE_HOME="$DIR/runtime/cache"
export XDG_DATA_HOME="$DIR/runtime/data"

NODE_BIN=$(get_node_binary)
CLAW_BIN=$(get_openclaw_binary)

ACCOUNT_ARG=""
[ -n "$ACCOUNT" ] && ACCOUNT_ARG="--account $ACCOUNT"

echo "📱 Matrix 设备管理 (Pod: $PROFILE)"
echo "========================================"

case "$COMMAND" in
    list)
        echo ""
        echo "📋 正在列出设备..."
        $NODE_BIN $CLAW_BIN matrix devices list $ACCOUNT_ARG
        ;;
    prune-stale)
        echo ""
        echo "🧹 正在清理过期设备..."
        $NODE_BIN $CLAW_BIN matrix devices prune-stale $ACCOUNT_ARG
        ;;
    *)
        echo "未知命令: $COMMAND"
        usage
        ;;
esac