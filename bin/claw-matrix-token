#!/bin/bash
# bin/claw-matrix-token — Matrix Token 验证工具
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

usage() {
    echo "用法: $(basename "$0") <PROFILE> <COMMAND> [OPTIONS]"
    echo ""
    echo "Matrix Token 验证与管理工具"
    echo ""
    echo "命令:"
    echo "  verify                  验证当前配置的 Token 有效性"
    echo "  login <user> <password> 通过密码登录获取 Token"
    echo "  logout                  清除已缓存的凭证"
    echo ""
    echo "示例:"
    echo "  $(basename "$0") main verify"
    echo "  $(basename "$0") main login @bot:example.org mypassword"
    echo "  $(basename "$0") main logout"
    exit 1
}

if [ "$#" -lt 2 ]; then
    usage
fi

PROFILE="$1"
COMMAND="$2"
shift 2

resolve_pod "$PROFILE"

export OPENCLAW_STATE_DIR="$DIR"
export OPENCLAW_CONFIG_PATH="$DIR/openclaw.json"
export TMPDIR="$DIR/runtime/tmp"
export XDG_CONFIG_HOME="$DIR/runtime/config"
export XDG_CACHE_HOME="$DIR/runtime/cache"
export XDG_DATA_HOME="$DIR/runtime/data"

NODE_BIN=$(get_node_binary)
CLAW_BIN=$(get_openclaw_binary)

echo "🔑 Matrix Token 管理 (Pod: $PROFILE)"
echo "========================================"

# 获取 Matrix 配置
get_matrix_config() {
    python3 << EOF
import json
import sys

config_path = '$DIR/openclaw.json'
try:
    with open(config_path, 'r') as f:
        config = json.load(f)
    
    matrix = config.get('channels', {}).get('matrix', {})
    if not matrix:
        print("NO_MATRIX")
        sys.exit(0)
    
    homeserver = matrix.get('homeserver', '')
    userId = matrix.get('userId', '')
    accessToken = matrix.get('accessToken', '')
    
    if not homeserver:
        print("NO_HOMESERVER")
        sys.exit(0)
    
    print(f"HOMESERVER={homeserver}")
    if userId:
        print(f"USER_ID={userId}")
    if accessToken:
        print(f"TOKEN_PRESENT=yes")
        print(f"TOKEN={accessToken[:20]}...")
except Exception as e:
    print(f"ERROR: {e}")
    sys.exit(1)
EOF
}

case "$COMMAND" in
    verify)
        echo ""
        echo "🔍 正在读取 Matrix 配置..."
        CONFIG_OUTPUT=$(get_matrix_config)
        
        if [ "$CONFIG_OUTPUT" = "NO_MATRIX" ]; then
            echo "❌ 错误: Pod '$PROFILE' 未配置 Matrix 渠道"
            exit 1
        fi
        
        if [ "$CONFIG_OUTPUT" = "NO_HOMESERVER" ]; then
            echo "❌ 错误: Matrix homeserver 未配置"
            exit 1
        fi
        
        echo "   $CONFIG_OUTPUT"
        echo ""
        
        # 解析配置
        eval "$CONFIG_OUTPUT"
        
        TOKEN="${TOKEN:-}"
        USER_ID="${USER_ID:-}"
        TOKEN_PRESENT="${TOKEN_PRESENT:-no}"
        
        if [ "$TOKEN_PRESENT" = "yes" ] && [ -n "$TOKEN" ]; then
            echo "✅ 已配置访问令牌 (accessToken)"
            echo "   Token: ${TOKEN}..."
            echo ""
            echo "💡 提示: Token 有效性将在 OpenClaw 启动时自动验证。"
            echo "   如需手动验证，请检查 journalctl 日志:"
            echo "   journalctl --user -u openclaw-gateway@$PROFILE.service -f"
        fi
        
        if [ -n "$USER_ID" ]; then
            echo "✅ 已配置用户 ID"
            echo "   用户: $USER_ID"
            echo ""
            echo "💡 提示: 使用密码登录时，凭证会在登录后自动缓存。"
        fi
        
        if [ "$TOKEN_PRESENT" != "yes" ] && [ -z "$USER_ID" ]; then
            echo "❌ 错误: 未配置 Token 或用户凭证"
            echo ""
            echo "💡 可选方案:"
            echo "   1. 使用 Token: ./bin/claw-matrix-add $PROFILE --token <TOKEN>"
            exit 1
        fi
        ;;
        
    login)
        if [ "$#" -lt 2 ]; then
            echo "错误: login 命令需要用户 ID 和密码参数"
            echo "用法: $(basename "$0") $PROFILE login <USER_ID> <PASSWORD>"
            exit 1
        fi
        
        USER_ID="$1"
        PASSWORD="$2"
        
        echo ""
        echo "🔐 正在通过密码登录获取 Token..."
        echo "   用户: $USER_ID"
        
        # 获取 homeserver
        HOMESERVER=$(python3 -c "
import json
with open('$DIR/openclaw.json', 'r') as f:
    config = json.load(f)
print(config.get('channels', {}).get('matrix', {}).get('homeserver', ''))
" 2>/dev/null || echo "")
        
        if [ -z "$HOMESERVER" ]; then
            echo "❌ 错误: 请先配置 homeserver"
            echo "   使用: ./bin/claw-matrix-add $PROFILE --homeserver <URL>"
            exit 1
        fi
        
        echo "   Homeserver: $HOMESERVER"
        echo ""
        
        # 调用 OpenClaw 登录
        # 注意: OpenClaw 本身不支持命令行密码登录，这里是占位实现
        # 实际需要用户在 Element 等客户端完成首次登录
        echo "⚠️  提示: OpenClaw 不支持命令行密码登录。"
        echo ""
        echo "💡 替代方案:"
        echo "   1. 在 Element 中登录后，从开发者工具获取 accessToken"
        echo "   2. 使用 Token 配置: ./bin/claw-matrix-add $PROFILE --token <TOKEN>"
        echo "   3. 或配置环境变量后重启服务，让 OpenClaw 自动读取"
        ;;
        
    logout)
        echo ""
        echo "🧹 正在清除 Matrix 凭证..."
        
        # 清除缓存的凭证
        CRED_DIR="$DIR/credentials/matrix"
        if [ -d "$CRED_DIR" ]; then
            rm -rf "$CRED_DIR"
            echo "✅ 已清除缓存凭证"
        else
            echo "ℹ️  无缓存凭证需要清除"
        fi
        
        # 清除配置中的敏感信息
        python3 << EOF
import json

config_path = '$DIR/openclaw.json'
with open(config_path, 'r') as f:
    config = json.load(f)

if 'channels' in config and 'matrix' in config['channels']:
    matrix = config['channels']['matrix']
    # 保留非敏感配置
    changes = []
    if 'password' in matrix:
        changes.append('password')
    if 'accessToken' in matrix:
        changes.append('accessToken')
    
    if changes:
        for key in changes:
            del matrix[key]
        
        with open(config_path, 'w') as f:
            json.dump(config, f, indent=2)
        
        print(f"CLEARED: {', '.join(changes)}")
    else:
        print("NO_SECRETS")
else:
    print("NO_MATRIX")
EOF
        
        echo ""
        echo "🔄 正在重启 Pod '$PROFILE'..."
        systemctl --user restart "$SERVICE_NAME.service" 2>/dev/null || true
        sleep 2
        echo "✅ 已完成"
        ;;
        
    *)
        echo "未知命令: $COMMAND"
        usage
        ;;
esac