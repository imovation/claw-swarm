#!/usr/bin/env python3
"""
bin/claw-apply — 声明式控制器（类 kubectl apply）
读取 swarm.yaml 的期望状态，并通过 clawctl 调谐每个 Pod。
增强功能：根据 global.orphan_policy 自动处理孤儿 Pod。
"""
import os
import yaml
import subprocess
import sys
from pathlib import Path

# 将 lib 目录加入模块搜索路径，以便导入共享库
# 脚本位于 bin/ 目录下，所以需要向上一级找到项目根目录
SCRIPT_DIR = Path(__file__).resolve().parent  # bin/ 目录
PROJECT_ROOT = SCRIPT_DIR.parent              # 项目根目录
LIB_DIR = PROJECT_ROOT / "lib"                # lib/ 目录

sys.path.insert(0, str(LIB_DIR))
from pod_utils import (
    get_swarm_config,
    resolve_pod,
    get_actual_services,
    systemd_reload_restart,
    pod_health_check,
)

CONFIG_FILE = PROJECT_ROOT / "swarm.yaml"
BIN_DIR = PROJECT_ROOT / "bin"


def run_command(cmd):
    """运行命令并实时输出至终端。"""
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError:
        return False


def apply_pod(pod_config):
    """使用 clawctl 调谐单个 Pod（创建/更新）。"""
    name = pod_config['name']
    profile = pod_config.get('profile', name)
    port = pod_config['port']
    token = pod_config['token']
    browser_mode = pod_config.get('resources', {}).get('browser', 'dedicated')

    # 构造 clawctl 调用参数（使用原始 profile 名称，让 clawctl 内部 resolve_pod 处理别名）
    cmd = [
        str(BIN_DIR / "clawctl"),
        profile,
        str(port),
        token,
        browser_mode,
    ]
    if run_command(cmd):
        print(f"   [实例 {name}] ✅ 同步成功。")
    else:
        print(f"   [实例 {name}] ❌ 同步失败。")
    sys.stdout.flush()


def handle_orphans(desired_pods, actual_services, orphan_policy):
    """
    根据 orphan_policy 处理孤儿 Pod（在实际运行中但未在 swarm.yaml 中定义的 Pod）。
    """
    desired_names = set(desired_pods.keys())
    actual_names = set(actual_services.keys())
    orphans = actual_names - desired_names  # 实际存在但未声明的 Pod

    if not orphans:
        return  # 没有孤儿

    print(f"\n🔍 发现 {len(orphans)} 个孤儿 Pod: {', '.join(sorted(orphans))}")

    if orphan_policy == "delete":
        print("🗑️  根据 global.orphan_policy: delete，正在清理孤儿 Pod...")
        for name in orphans:
            info = actual_services[name]
            profile = info["profile"]
            service_name = info["service"]

            print(f"   正在停止并移除孤儿 Pod: {name} (profile: {profile})...")
            subprocess.run(["systemctl", "--user", "stop", f"{service_name}.service"], check=False)
            subprocess.run(["systemctl", "--user", "disable", f"{service_name}.service"], check=False)

            service_file = Path.home() / ".config" / "systemd" / "user" / f"{service_name}.service"
            if service_file.exists():
                service_file.unlink()

            pod_dir = Path.home() / (".openclaw" if profile == "default" else f".openclaw-{profile}")
            if pod_dir.exists():
                import shutil
                shutil.rmtree(pod_dir)

            print(f"   ✅ 孤儿 Pod {name} 已清理。")
        # 清理后重载 Systemd
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=False)
        print("   🔄 Systemd 已重载。")
    elif orphan_policy == "warn":
        print("⚠️  根据 global.orphan_policy: warn，仅提醒未采取行动。")
        print("   如需自动清理，请将 swarm.yaml 中的 global.orphan_policy 设置为 'delete'。")
    else:
        print(f"⚠️  未知的 orphan_policy: '{orphan_policy}'，默认采用 warn 策略。")


def main():
    if not CONFIG_FILE.exists():
        print(f"❌ 错误: 找不到配置文件 {CONFIG_FILE}。")
        sys.exit(1)

    # 读取期望状态（swarm.yaml）
    try:
        config = get_swarm_config(CONFIG_FILE)
    except Exception as e:
        print(f"❌ 读取 swarm.yaml 失败: {e}")
        sys.exit(1)

    pods = config.get('pods', [])
    orphan_policy = config.get('global', {}).get('orphan_policy', 'warn')

    # 构建期望 Pod 字典：{name: pod_config}
    desired_pods = {pod['name']: pod for pod in pods}

    # 感知现状：通过 Systemd 获取正在运行的服务
    actual_services = get_actual_services()

    # 1. 调谐所有已声明的 Pod（创建/更新）
    for pod in pods:
        apply_pod(pod)

    # 2. 处理孤儿 Pod
    handle_orphans(desired_pods, actual_services, orphan_policy)

    # 3. 显示最终状态看板
    print("\n" + "=" * 30 + " 🐝 集群最终状态看板 " + "=" * 30)
    sys.stdout.flush()
    subprocess.run([str(BIN_DIR / "claw-status")])


if __name__ == "__main__":
    main()
