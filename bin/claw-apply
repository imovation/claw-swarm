#!/usr/bin/env python3
"""
bin/claw-apply — 声明式控制器（类 kubectl apply）
读取 swarm.yaml 的期望状态，调用新模块层代码调和每个 Pod。

⚠️  [已迁移 MIGRATED] 本脚本已重构为调用新模块层代码：
    modules/orchestration/reconciler/reconciler.py
    modules/orchestration/pod-provisioner/provisioner.py
    modules/orchestration/config-parser/parser.py
"""
import os
import sys
import subprocess
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
PROJECT_ROOT = SCRIPT_DIR.parent
BIN_DIR = PROJECT_ROOT / "bin"
CONFIG_FILE = PROJECT_ROOT / "swarm.yaml"


def check_and_update_openclaw(skip_update=False, auto_yes=False, non_interactive=False):
    """检测版本并询问用户是否更新。"""
    from lib.pod_utils import get_openclaw_versions
    local_v, remote_v = get_openclaw_versions()
    
    if local_v == "error" or remote_v == "error":
        return False
    
    print(f"🔍 正在检测 OpenClaw 版本: 当前={local_v}, 最新={remote_v}")
    
    if local_v != remote_v and remote_v != "unknown":
        print(f"\n✨ 发现新版本 OpenClaw: {local_v} -> {remote_v}")
        
        if skip_update:
            print("⏭️  已跳过版本更新 (--skip-update)")
            return False
        
        if auto_yes:
            choice = 'y'
            print("🤖 自动确认更新 (--yes)")
        elif non_interactive:
            print("⏭️  非交互模式，跳过更新")
            return False
        else:
            try:
                choice = input("❓ 是否现在更新 OpenClaw? (y/N): ").lower()
            except EOFError:
                choice = 'n'
        
        if choice == 'y':
            print(f"🚀 正在更新 OpenClaw 到 {remote_v}...")
            try:
                subprocess.run(["npm", "install", "-g", "openclaw"], check=True)
                print("✅ OpenClaw 已更新。")
                return True
            except Exception as e:
                print(f"❌ 更新失败: {e}")
    else:
        print("✅ OpenClaw 已是最新版。")
    return False


def main():
    import argparse
    
    parser = argparse.ArgumentParser(description='Claw-Swarm 声明式控制器')
    parser.add_argument('--skip-update', action='store_true', help='跳过 OpenClaw 版本检测')
    parser.add_argument('--yes', '-y', action='store_true', help='自动确认版本更新')
    parser.add_argument('--dry-run', action='store_true', help='仅预览变更，不实际执行')
    parser.add_argument('--skip-matrix', action='store_true', help='跳过 Matrix 配置')
    args = parser.parse_args()

    non_interactive = not sys.stdin.isatty()

    if not CONFIG_FILE.exists():
        print(f"❌ 错误: 找不到配置文件 {CONFIG_FILE}。")
        sys.exit(1)

    # 0. 版本检查
    if not args.skip_update:
        check_and_update_openclaw(args.skip_update, args.yes, non_interactive)

    # 调用新模块层代码
    MODULE_DIR = PROJECT_ROOT / "modules" / "orchestration"
    sys.path.insert(0, str(MODULE_DIR / "config-parser"))
    sys.path.insert(0, str(MODULE_DIR / "reconciler"))
    sys.path.insert(0, str(MODULE_DIR / "pod-provisioner"))

    from parser import parse as parse_config
    from reconciler import compute_diff, get_actual_state, handle_orphans
    from provisioner import provision

    try:
        config = parse_config(CONFIG_FILE)
    except Exception as e:
        print(f"❌ 读取或解析 swarm.yaml 失败: {e}")
        sys.exit(1)

    actual = get_actual_state()
    diff = compute_diff(config, actual)

    if args.dry_run:
        print("\n🌀 === DRY RUN 模式 ===")
        print(f"将新建 {len(diff['to_create'])} 个 Pod:")
        for pod in diff["to_create"]:
            print(f"   + {pod.name} (profile: {pod.profile}, port: {pod.port})")
        print(f"将更新 {len(diff['to_update'])} 个 Pod:")
        for pod in diff["to_update"]:
            print(f"   ~ {pod.name} (profile: {pod.profile}, port: {pod.port})")
        if diff["orphans"]:
            print(f"\n发现 {len(diff['orphans'])} 个孤儿 Pod: {', '.join(diff['orphans'])}")
            print(f"   策略: {config.orphan_policy}")
        print("\n✅ Dry run 完成，未执行实际变更。")
        sys.exit(0)

    # 1. 调和 Pod (使用新模块 provisioner)
    all_pods = diff["to_create"] + diff["to_update"]
    for pod in all_pods:
        all_plugins = list(set(config.plugins + pod.plugins))
        proxy_dict = {
            "http": config.proxy.http,
            "https": config.proxy.https,
            "socks": config.proxy.socks,
            "no_proxy": config.proxy.no_proxy,
        }
        print(f"▶️  正在同步实例: {pod.name}...")
        try:
            provision(
                profile=pod.profile,
                port=pod.port,
                token=pod.token,
                browser=pod.browser,
                plugins=all_plugins,
                proxy=proxy_dict,
            )
            print(f"   ✅ {pod.name} 同步成功。")
        except Exception as e:
            print(f"   ❌ {pod.name} 同步失败: {e}")
        sys.stdout.flush()

    # 2. 处理孤儿
    handle_orphans(diff["orphans"], actual, config.orphan_policy)

    # 3. 最终看板
    print("\n" + "=" * 30 + " 🐝 集群最终状态看板 " + "=" * 30)
    sys.stdout.flush()
    subprocess.run([str(BIN_DIR / "claw-status")])


if __name__ == "__main__":
    main()