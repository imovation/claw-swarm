#!/bin/bash
# bin/claw-agent-create — 创建 Agent 并可选绑定到飞书机器人
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/pod_utils.sh"

if [ "$#" -lt 2 ]; then
    echo "用法: $(basename "$0") <PROFILE_NAME> <AGENT_NAME> [BOT_ID]"
    echo ""
    echo "参数说明:"
    echo "  PROFILE_NAME  Pod 名称 (如 aimee)"
    echo "  AGENT_NAME   新 Agent 名称"
    echo "  BOT_ID       可选: 绑定的飞书机器人 ID"
    echo ""
    echo "示例: $(basename "$0") aimee aimee2 bot2"
    echo "      $(basename "$0") aimee aimee3"
    exit 1
fi

PROFILE_INPUT="$1"
AGENT_NAME="$2"
BOT_ID="${3:-}"

resolve_pod "$PROFILE_INPUT"

if [ ! -d "$DIR" ]; then
    echo "❌ 错误: Pod '$PROFILE_INPUT' 不存在"
    exit 1
fi

WORKSPACE="$DIR/workspace-$AGENT_NAME"

echo "🤖 正在创建 Agent '$AGENT_NAME' 在 Pod '$PROFILE_INPUT'..."

if [ -n "$BOT_ID" ]; then
    echo "🔗 同时绑定到飞书机器人 '$BOT_ID'..."
    openclaw --profile "$RESOLVED_PROFILE" agents add "$AGENT_NAME" \
        --workspace "$WORKSPACE" \
        --bind "feishu:$BOT_ID" \
        --non-interactive
else
    openclaw --profile "$RESOLVED_PROFILE" agents add "$AGENT_NAME" \
        --workspace "$WORKSPACE" \
        --non-interactive
fi

echo "🔄 重启服务..."
systemctl --user restart "$SERVICE_NAME.service"

echo ""
echo "✅ Agent '$AGENT_NAME' 创建完成"
echo "   Workspace: $WORKSPACE"
[ -n "$BOT_ID" ] && echo "   绑定 Bot: $BOT_ID"
