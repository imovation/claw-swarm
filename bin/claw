#!/usr/bin/env python3
"""
bin/claw — Claw-Swarm 统一 CLI 入口 (路由分发器)
类似 kubectl，所有子命令均路由至 modules/ 下对应功能层的实现。
"""
import sys
import os
import subprocess
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
PROJECT_ROOT = SCRIPT_DIR.parent
MODULE_ROOT = PROJECT_ROOT / "modules"

# ── 子命令路由表 ───────────────────────────────────────────────────────────────
ROUTES = {
    "apply":   MODULE_ROOT / "orchestration/reconciler/reconciler.py",
    "status":  MODULE_ROOT / "orchestration/status.py",
    "tui":     MODULE_ROOT / "orchestration/tui.py",
    "port":    MODULE_ROOT / "network-mesh/port-manager/port_manager.py",
    "repair":  MODULE_ROOT / "orchestration/pod-provisioner/repair.py",
    "rm":      MODULE_ROOT / "orchestration/pod-provisioner/remove.py",
    "ps":      MODULE_ROOT / "orchestration/ps.py",
}

# Matrix 子命令路由
MATRIX_ROUTES = {
    "add":      MODULE_ROOT / "matrix-channel/account-manager/account_manager.py",
    "verify":   MODULE_ROOT / "matrix-channel/e2ee-verifier/e2ee_verifier.py",
    "devices":  MODULE_ROOT / "matrix-channel/device-manager/device_manager.py",
    "pairing":  MODULE_ROOT / "matrix-channel/device-manager/device_manager.py",
}


def print_help():
    print("""bin/claw — Claw-Swarm 统一 CLI 入口

用法:
  claw apply               — 调和集群状态 (orchestration/reconciler)
  claw status              — 查看集群看板 (orchestration/status.py)
  claw tui <NAME>          — 进入实例 TUI (orchestration/tui.py)
  claw port <NAME> <PORT>  — 变更端口 (network-mesh/port-manager)
  claw repair <NAME>       — 修复实例 (orchestration/pod-provisioner/repair.py)
  claw rm <NAME>           — 销毁实例 (orchestration/pod-provisioner/remove.py)
  claw ps                  — 精细进程状态 (orchestration/ps.py)
  claw matrix add <PROFILE>  — 配置 Matrix 账号 (matrix-channel)
  claw matrix verify <PROFILE> status|bootstrap — E2EE 验证
  claw matrix devices <PROFILE> list|prune — 设备管理
  claw matrix pairing <PROFILE> list|approve — 配对审批""")


def route_matrix(args):
    """路由 matrix 子命令。"""
    if not args:
        print("用法: claw matrix <子命令> [参数...]")
        print("可用子命令:", ", ".join(MATRIX_ROUTES.keys()))
        sys.exit(1)

    sub = args[0]
    if sub not in MATRIX_ROUTES:
        print(f"❌ 未知的 matrix 子命令: '{sub}'")
        print("可用子命令:", ", ".join(MATRIX_ROUTES.keys()))
        sys.exit(1)

    target = MATRIX_ROUTES[sub]
    if not target.exists():
        print(f"❌ 找不到对应脚本: {target}")
        sys.exit(1)

    os.execv(sys.executable, [sys.executable, str(target)] + args[1:])


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print_help()
        sys.exit(0)

    cmd = sys.argv[1]
    remaining = sys.argv[2:]

    if cmd == "matrix":
        route_matrix(remaining)
        return

    if cmd not in ROUTES:
        print(f"❌ 未知子命令: '{cmd}'")
        print("可用子命令:", ", ".join(list(ROUTES.keys()) + ["matrix"]))
        sys.exit(1)

    target = ROUTES[cmd]
    if not target.exists():
        print(f"❌ 找不到对应脚本: {target}")
        sys.exit(1)

    os.execv(sys.executable, [sys.executable, str(target)] + remaining)


if __name__ == "__main__":
    main()